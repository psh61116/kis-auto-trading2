# ──────────────────────────────────────────────────
# 한국투자증권 API 설정
# 이 파일을 .env 로 복사한 뒤 실제 값을 입력하세요
# ──────────────────────────────────────────────────

# 한국투자증권 Open API 발급 키
KIS_APP_KEY=여기에_앱키_입력
KIS_APP_SECRET=여기에_앱시크릿_입력

# 계좌번호 (예: 12345678-01)
KIS_ACCOUNT_NO=12345678-01

# 모의투자 여부 (true = 모의투자, false = 실전투자)
KIS_IS_PAPER=true
